[bar/primary]
monitor               = HDMI-0
override-redirect     = false
wm-restack            = none

width                 = 100%
height                = 25
fixed-center          = true
offset-y              = 0
offset-x              = 0

border-top-size       = 0
border-bottom-size    = 0
border-right-size     = 0
border-left-size      = 0
border-color          = 0

tray-position         = none
tray-detached         = true

bottom                = false

font-0 = Hack:size=11;3
font-1 = FontAwesome:pixelsize=13;3

background        = #77000000
foreground        = #C5A9F9
padding-left      = 1
padding-right     = 1
module-margin     = 1.5
modules-left      = battery backlight volume
modules-center    = i3
modules-right     = cpu memory time

[bar/secondary]
monitor           = eDP-1-1
override-redirect = false
wm-restack        = none

width                 = 100%
height                = 25
fixed-center          = true
offset-y              = 0
offset-x              = 0

border-top-size       = 0
border-bottom-size    = 0
border-right-size     = 0
border-left-size      = 0
border-color          = 0

tray-position  = none
tray-detached  = true

bottom         = false

font-0         = Hack:size=11;3
font-1         = FontAwesome:pixelsize=13;3

background     = #77000000
foreground     = #C5A9F9
padding-left   = 1
padding-right  = 1
module-margin  = 1.5
modules-left   = battery backlight volume
modules-center = i3
modules-right  = cpu memory time

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 98
format-charging = <animation-charging> <label-charging>
format-discharging = <ramp-capacity> <label-discharging>
format-full-prefix = "’ēĆ "
ramp-capacity-0 = "’ēä"
ramp-capacity-1 = "’ēā"
ramp-capacity-2 = "’ēé"
ramp-capacity-3 = "’ēü "
ramp-capacity-4 = "’ēĆ"
animation-charging-0 = "’ēä"
animation-charging-1 = "’ēā"
animation-charging-2 = "’ēé"
animation-charging-3 = "’ēü"
animation-charging-framerate = 750

[module/i3]
type                        = internal/i3
pin-workspaces              = true
strip-wsnumbers             = true
enable-scroll               = false

label-focused-foreground = #AE81FF
label-focused-background = #55000000
label-focused-underline  = #FF8400
label-focused-padding    = 2

label-unfocused-foreground = #444444
label-unfocused-background = #
label-unfocused-underline  = #FF8400
label-unfocused-padding    = 2

label-visible-foreground = #444444
label-visible-background = #
label-visible-underline  = #FF8400
label-visible-padding    = 2

label-urgent-foreground = #FF8400
label-urgent-background = #
label-urgent-underline  = #FF8400
label-urgent-padding    = 2

[module/time]
type = internal/date
interval = 1.0
date = "’ĆŚ %H:%M %D"

[module/volume]
type = internal/volume

format-volume = <ramp-volume> <label-volume>
format-muted = "’Ć” 0%"

ramp-volume-0 = "’Ć¦ "
ramp-volume-1 = "’Ć¦ "
ramp-volume-2 = "’Ć© "

[module/cpu]
type = internal/cpu
label = "’Ćō %percentage%%"
label-maxlen = 50

[module/memory]
type = internal/memory
label = "’ŗø %gb_used%"

; vim:ft=dosini
