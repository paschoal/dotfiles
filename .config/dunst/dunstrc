[global]
  monitor              = 0
  follow               = mouse
  geometry             = "300x30-10+35"
  indicate_hidden      = yes
  shrink               = no
  notification_height  = 0
  separator_height     = 5
  padding              = 8
  horizontal_padding   = 8
  frame_width          = 2
  frame_color          = "#aaaaaa"
  separator_color      = frame
  sort                 = yes
  idle_threshold       = 120
  font                 = Hack 10
  line_height          = 0
  markup               = full
  format               = "<b>%s</b>\n%b"
  alignment            = left
  show_age_threshold   = 60
  word_wrap            = yes
  ellipsize            = middle
  ignore_newline       = no
  stack_duplicates     = true
  hide_duplicate_count = false
  show_indicators      = yes
  icon_position        = off
  max_icon_size        = 32
  icon_path            = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/
  sticky_history       = yes
  history_length       = 20

  ### Misc/Advanced ###
  dmenu                = /usr/bin/dmenu -p dunst:
  browser              = /usr/bin/qutebrowser
  always_run_script    = true
  title                = Dunst
  class                = Dunst
  startup_notification = false
  force_xinerama       = false

[experimental]
    per_monitor_dpi = false

[shortcuts]
    close       = ctrl+space
    close_all   = ctrl+shift+space
    history     = ctrl+grave
    context     = ctrl+shift+period

[urgency_low]
    background  = "#272822"
    foreground  = "#66D9EF"
    frame_color = "#66D9EF"
    timeout     = 10

[urgency_normal]
    background  = "#272822"
    foreground  = "#FD971F"
    frame_color = "#FD971f"
    timeout     = 10

[urgency_critical]
    background  = "#272822"
    foreground  = "#F92672"
    frame_color = "#F92672"
    timeout     = 0

# vim: ft=cfg
